{
  "expo": {
    "name": "Linkora",
    "slug": "linkora",
    "scheme": "linkora",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0B0F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
   "plugins": [
  "expo-router",
  "expo-font",
  "expo-secure-store",
  "@react-native-community/datetimepicker",
  [
    "expo-location",
    {
      "locationAlwaysAndWhenInUsePermission": "Allow Linkora to access your location"
    }
  ]
],
    "experiments": {
      "typedRoutes": false
    },
    "ios": {
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSExceptionDomains": {
            "192.168.137.163": {
              "NSIncludesSubdomains": true,
              "NSTemporaryExceptionAllowsInsecureHTTPLoads": true,
              "NSTemporaryExceptionMinimumTLSVersion": "TLSv1.1"
            },
            "localhost": {
              "NSIncludesSubdomains": true,
              "NSTemporaryExceptionAllowsInsecureHTTPLoads": true
            }
          }
        }
      },
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.linkora"
    },
    "android": {
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0B0B0F"
      },
      "package": "com.yourcompany.linkora"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "extra": {
      "apiUrl": "http://192.168.137.163:8000"
    }
  }
}